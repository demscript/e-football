# Database
DATABASE_URL="postgresql://username:password@localhost:5432/efootball_tournament?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-min-32-chars-long"

# Admin credentials (used for seeding)
ADMIN_EMAIL="admin@efootball.local"
ADMIN_PASSWORD="Admin@12345"

# Pusher (Realtime) - Get from pusher.com (free tier available)
PUSHER_APP_ID="your-pusher-app-id"
PUSHER_KEY="your-pusher-key"
PUSHER_SECRET="your-pusher-secret"
PUSHER_CLUSTER="eu"

NEXT_PUBLIC_PUSHER_KEY="your-pusher-key"
NEXT_PUBLIC_PUSHER_CLUSTER="eu"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
